{
  "sourceLanguage": "en",
  "strings": {
    "%@ · newer": {
      "comment": "Conflict card date, flagged as the newer of the two. %@ is a date.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · newer"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · новее"
          }
        }
      }
    },
    "%lld items couldn’t be put back: %@": {
      "comment": "Undo failure line. First argument is a count, second the underlying error.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%#@items@ couldn’t be put back: %2$@"
          },
          "substitutions": {
            "items": {
              "argNum": 1,
              "formatSpecifier": "lld",
              "variations": {
                "plural": {
                  "one": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg item"
                    }
                  },
                  "other": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg items"
                    }
                  }
                }
              }
            }
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось вернуть %#@items@: %2$@"
          },
          "substitutions": {
            "items": {
              "argNum": 1,
              "formatSpecifier": "lld",
              "variations": {
                "plural": {
                  "one": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg объект"
                    }
                  },
                  "few": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg объекта"
                    }
                  },
                  "many": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg объектов"
                    }
                  },
                  "other": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg объектов"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "%lld items couldn’t be re-applied: %@": {
      "comment": "Redo failure line. First argument is a count, second the underlying error.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%#@items@ couldn’t be re-applied: %2$@"
          },
          "substitutions": {
