    "%lld of %lld": {
      "comment": "Quick View header position readout: %1$lld is the cursor's place, %2$lld the count.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld of %lld"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld из %2$lld"
          }
        }
      }
    },
    "%lld of %lld selected · %@": {
      "comment": "Pane status line while rows are marked. %1$lld is the marked count, %2$lld the total in the folder, %3$@ their combined size.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld of %lld selected · %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбрано %1$lld из %2$lld · %3$@"
          }
        }
      }
    },
    "%lld of %lld will be renamed": {
      "comment": "Multi-rename status: N of M items will change name. Verb is invariant.",
