{
  "sourceLanguage": "en",
  "strings": {
    "%@ (default)": {
      "comment": "Open With menu item for the app a double-click would use; %@ is the app name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ (default)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ (по умолчанию)"
          }
        }
      }
    },
    "%@ available of %@": {
      "comment": "Volume capacity tooltip; %1$@ is free space, %2$@ is total capacity.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ available of %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Свободно %@ из %@"
          }
        }
      }
    },
    "%@ is installed but couldn’t be launched.": {
      "comment": "Compare failure detail; %@ is the diff tool name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is installed but couldn’t be launched."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Программа %@ установлена, но её не удалось запустить."
          }
        }
      }
    },
    "%@ may take a long time to compare them, or become unresponsive.": {
      "comment": "Oversized-compare warning body; %@ is the diff tool name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ may take a long time to compare them, or become unresponsive."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Программа %@ может долго их сравнивать или перестать отвечать."
          }
        }
      }
    },
    "%@ · newer": {
      "comment": "Conflict card date, flagged as the newer of the two. %@ is a date.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · newer"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · новее"
          }
        }
      }
    },
    "%lld items are already back": {
      "comment": "Put-Back result for several blocked items; %lld is the count.",
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld item is already back"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld items are already back"
                }
              }
            }
          }
        },
        "ru": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld объект уже возвращён"
                }
              },
              "few": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld объекта уже возвращены"
                }
              },
              "many": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld объектов уже возвращены"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld объектов уже возвращены"
                }
              }
            }
          }
        }
      }
    },
    "%lld items couldn’t be put back: %@": {
      "comment": "Undo failure line. First argument is a count, second the underlying error.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%#@items@ couldn’t be put back: %2$@"
          },
          "substitutions": {
            "items": {
              "argNum": 1,
              "formatSpecifier": "lld",
              "variations": {
                "plural": {
                  "one": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg item"
                    }
                  },
                  "other": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg items"
                    }
                  }
                }
              }
            }
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось вернуть %#@items@: %2$@"
          },
          "substitutions": {
            "items": {
              "argNum": 1,
              "formatSpecifier": "lld",
              "variations": {
                "plural": {
                  "one": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg объект"
                    }
                  },
                  "few": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg объекта"
                    }
                  },
                  "many": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg объектов"
                    }
                  },
                  "other": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg объектов"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "%lld items couldn’t be re-applied: %@": {
      "comment": "Redo failure line. First argument is a count, second the underlying error.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%#@items@ couldn’t be re-applied: %2$@"
          },
          "substitutions": {
            "items": {
              "argNum": 1,
              "formatSpecifier": "lld",
              "variations": {
                "plural": {
                  "one": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg item"
                    }
                  },
                  "other": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg items"
                    }
                  }
                }
              }
            }
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось повторно применить %#@items@: %2$@"
          },
          "substitutions": {
            "items": {
              "argNum": 1,
              "formatSpecifier": "lld",
              "variations": {
                "plural": {
                  "one": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg объект"
                    }
                  },
                  "few": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg объекта"
                    }
                  },
                  "many": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg объектов"
                    }
                  },
                  "other": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%arg объектов"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "%lld items overwrote existing files and can’t be restored.": {
      "comment": "One line of the “undo finished with issues” alert.",
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld item overwrote existing files and can’t be restored."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld items overwrote existing files and can’t be restored."
                }
              }
            }
          }
        },
        "ru": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld объект перезаписал существующие файлы, его нельзя восстановить."
                }
              },
              "few": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld объекта перезаписали существующие файлы, их нельзя восстановить."
                }
              },
              "many": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld объектов перезаписали существующие файлы, их нельзя восстановить."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld объектов перезаписали существующие файлы, их нельзя восстановить."
                }
              }
            }
          }
        }
      }
    },
    "A row of F-key buttons along the window bottom — Rename, View, Copy, Move, New Folder, Delete — the Total Commander function bar. Also in the View menu; the keys work whether or not the bar is shown.": {
      "comment": "Panels footer: function key bar.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A row of F-key buttons along the window bottom — Rename, View, Copy, Move, New Folder, Delete — the Total Commander function bar. Also in the View menu; the keys work whether or not the bar is shown."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ряд кнопок с F-клавишами вдоль нижнего края окна — Переименовать, Просмотр, Копировать, Переместить, Новая папка, Удалить — панель функций Total Commander. Также доступно в меню «Вид»; клавиши работают независимо от того, показана панель или нет."
          }
        }
      }
    },
    "Abort": {
      "comment": "Error resolution button: stop the whole operation.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Abort"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прервать"
          }
        }
      }
    },
    "Add Shortcut": {
      "comment": "Shortcut recorder placeholder when no shortcut is set.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add Shortcut"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавить сочетание"
          }
        }
      }
    },
    "All Tags…": {
      "comment": "Sidebar row that reveals every custom tag found while browsing.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All Tags…"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все метки…"
          }
        }
      }
    },
    "All tags": {
      "comment": "Accessibility label for the sidebar's “All Tags…” row glyph.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All tags"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все метки"
          }
        }
      }
    },
    "All your shortcut customizations will be removed and the macOS defaults restored. All your changes will be lost.": {
      "comment": "Shortcuts: restore-defaults confirmation body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All your shortcut customizations will be removed and the macOS defaults restored. All your changes will be lost."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все ваши изменения сочетаний будут удалены и восстановлены стандартные значения macOS. Все изменения будут потеряны."
          }
        }
      }
    },
    "Already here": {
      "comment": "Conflict card header for the existing item.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Already here"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Уже здесь"
          }
        }
      }
    },
    "Also assigned to %@": {
      "comment": "Shortcuts conflict tooltip. %@ is a comma-separated list of command titles.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Also assigned to %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Также назначено: %@"
          }
        }
      }
    },
    "Also offers pre-release builds when Dirnex checks for updates. Betas are newer but less tested; you're moved back onto a stable release automatically once one catches up.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Also offers pre-release builds when Dirnex checks for updates. Betas are newer but less tested; you're moved back onto a stable release automatically once one catches up."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "При проверке обновлений будут предлагаться и предварительные сборки. Бета-версии новее, но менее протестированы; как только выйдет стабильная версия того же уровня, вы автоматически вернётесь на неё."
          }
        }
      }
    },
    "An item with that name already exists here.": {
      "comment": "Error sentence: already exists.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An item with that name already exists here."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Объект с таким именем уже есть здесь."
          }
        }
      }
    },
    "An item with the same name is already here. Choose how to resolve it.": {
      "comment": "Conflict sheet body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An item with the same name is already here. Choose how to resolve it."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Объект с таким именем уже есть здесь. Выберите, как поступить."
          }
        }
      }
    },
    "Another saved search already uses that name. Pick a different one.": {
      "comment": "Body of the saved-search rename-collision alert.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Another saved search already uses that name. Pick a different one."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это имя уже занято другим сохранённым поиском. Выберите другое."
          }
        }
      }
    },
    "Apply to all remaining conflicts": {
      "comment": "Conflict sheet: suppression checkbox.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apply to all remaining conflicts"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Применить ко всем остальным конфликтам"
          }
        }
      }
    },
    "Apply to all remaining errors": {
      "comment": "Error sheet: suppression checkbox.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apply to all remaining errors"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Применить ко всем остальным ошибкам"
          }
        }
      }
    },
    "Ask before moving items to the Trash": {
      "comment": "Operations toggle.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ask before moving items to the Trash"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Спрашивать перед перемещением в Корзину"
          }
        }
      }
    },
    "Automatic": {
      "comment": "Picker option: choose the tool/editor automatically.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatic"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Автоматически"
          }
        }
      }
    },
    "Automatic (%@)": {
      "comment": "Editor picker option naming the automatic choice. %@ is an app name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatic (%@)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Автоматически (%@)"
          }
        }
      }
    },
    "Back": {
      "comment": "Tour: previous-screen button.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Back"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Назад"
          }
        }
      }
    },
    "Badges a file whose bytes are still in iCloud (or another provider), on their way up or down, or in conflict — at the right edge of its name, as Finder does. Folders outside a cloud provider are never scanned, and fully synced files show nothing. Also in the View menu.": {
      "comment": "Panels footer: sync status.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Badges a file whose bytes are still in iCloud (or another provider), on their way up or down, or in conflict — at the right edge of its name, as Finder does. Folders outside a cloud provider are never scanned, and fully synced files show nothing. Also in the View menu."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отмечает значком файл, данные которого ещё в iCloud (или у другого провайдера), загружаются или выгружаются либо в состоянии конфликта — у правого края имени, как в Finder. Папки вне облачного провайдера не сканируются, а полностью синхронизированные файлы ничем не отмечаются. Также доступно в меню «Вид»."
          }
        }
      }
    },
    "Cancel": {
      "comment": "Conflict dialog cancel button.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отмена"
          }
        }
      }
    },
    "Can’t copy here": {
      "comment": "Copy failure title: destination can't receive files.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can’t copy here"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сюда нельзя копировать"
          }
        }
      }
    },
    "Can’t copy into the same folder": {
      "comment": "Copy failure title: source and destination are the same folder.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can’t copy into the same folder"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нельзя копировать в ту же папку"
          }
        }
      }
    },
    "Can’t create the file": {
      "comment": "Create-file failure title for an invalid name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can’t create the file"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось создать файл"
          }
        }
      }
    },
    "Can’t create the folder": {
      "comment": "New Folder failure title for an invalid name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can’t create the folder"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось создать папку"
          }
        }
      }
    },
    "Can’t create “%@”": {
      "comment": "New Folder failure title; %@ is the folder name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can’t create “%@”"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось создать «%@»"
          }
        }
      }
    },
    "Can’t edit “%@”": {
      "comment": "Edit-file failure title; %@ is the name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can’t edit “%@”"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нельзя изменить «%@»"
          }
        }
      }
    },
    "Can’t move here": {
      "comment": "Move failure title: destination can't receive files.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can’t move here"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сюда нельзя переместить"
          }
        }
      }
    },
    "Can’t move into the same folder": {
      "comment": "Move failure title: source and destination are the same folder.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can’t move into the same folder"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нельзя переместить в ту же папку"
          }
        }
      }
    },
    "Can’t open “%@”": {
      "comment": "Directory-load failure sheet title. %@ is a name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can’t open “%@”"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось открыть «%@»"
          }
        }
      }
    },
    "Choose an Application": {
      "comment": "Open panel title for picking an app in Open With ▸ Other…",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose an Application"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите программу"
          }
        }
      }
    },
    "Collapsed": {
      "comment": "Accessibility state of a folded sidebar section's disclosure triangle.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Collapsed"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Свёрнуто"
          }
        }
      }
    },
    "Compare Anyway": {
      "comment": "Proceed button on the oversized-compare warning.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Compare Anyway"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Всё равно сравнить"
          }
        }
      }
