    "Automatic": {
      "comment": "Picker option: choose the tool/editor automatically.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatic"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Автоматически"
          }
        }
      }
    },
    "Automatic (%@)": {
      "comment": "Editor picker option naming the automatic choice. %@ is an app name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatic (%@)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Автоматически (%@)"
          }
        }
      }
    },
    "Back": {
      "comment": "Tour: previous-screen button.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Back"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Назад"
          }
        }
      }
    },
    "Badges a file whose bytes are still in iCloud (or another provider), on their way up or down, or in conflict — at the right edge of its name, as Finder does. Folders outside a cloud provider are never scanned, and fully synced files show nothing. Also in the View menu.": {
      "comment": "Panels footer: sync status.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Badges a file whose bytes are still in iCloud (or another provider), on their way up or down, or in conflict — at the right edge of its name, as Finder does. Folders outside a cloud provider are never scanned, and fully synced files show nothing. Also in the View menu."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отмечает значком файл, данные которого ещё в iCloud (или у другого провайдера), загружаются или выгружаются либо в состоянии конфликта — у правого края имени, как в Finder. Папки вне облачного провайдера не сканируются, а полностью синхронизированные файлы ничем не отмечаются. Также доступно в меню «Вид»."
          }
        }
      }
    },
    "Cancel": {
      "comment": "Conflict dialog cancel button.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отмена"
          }
        }
      }
    },
    "Can’t open “%@”": {
      "comment": "Directory-load failure sheet title. %@ is a name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can’t open “%@”"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось открыть «%@»"
          }
        }
      }
    },
    "Compare By Contents (⌥F3) needs a diff tool. Install FileMerge (part of Xcode), Kaleidoscope, or BBEdit, then reopen Settings.": {
      "comment": "Operations footer: no diff tool installed.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Compare By Contents (⌥F3) needs a diff tool. Install FileMerge (part of Xcode), Kaleidoscope, or BBEdit, then reopen Settings."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для «Сравнить по содержимому» (⌥F3) нужен инструмент сравнения. Установите FileMerge (входит в Xcode), Kaleidoscope или BBEdit, затем откройте настройки заново."
          }
        }
      }
    },
    "Compare files with": {
      "comment": "Operations picker label: diff tool.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Compare files with"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сравнивать файлы с помощью"
          }
        }
      }
    },
    "Couldn’t copy “%@”": {
      "comment": "Per-file error sheet title. %@ is a name.",
      "localizations": {
