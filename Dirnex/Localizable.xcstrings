{
  "sourceLanguage": "en",
  "strings": {
    "%@ (default)": {
      "comment": "Open With menu item for the app a double-click would use; %@ is the app name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ (default)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ (по умолчанию)"
          }
        }
      }
    },
    "%@ / %@": {
      "comment": "Queue row byte readout: %1$@ transferred / %2$@ total.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ / %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ / %2$@"
          }
        }
      }
    },
    "%@ available of %@": {
      "comment": "Volume capacity tooltip; %1$@ is free space, %2$@ is total capacity.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ available of %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Свободно %@ из %@"
          }
        }
      }
    },
    "%@ is installed but couldn’t be launched.": {
      "comment": "Compare failure detail; %@ is the diff tool name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is installed but couldn’t be launched."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Программа %@ установлена, но её не удалось запустить."
          }
        }
      }
    },
    "%@ key": {
      "comment": "Host-key-change body; %@ is the key type, e.g. RSA.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ key"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ключ %@"
          }
        }
      }
    },
    "%@ left": {
      "comment": "Queue-bar ETA readout; %@ is a formatted duration, e.g. “2 min left”.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ left"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "осталось %@"
          }
        }
      }
    },
    "%@ may take a long time to compare them, or become unresponsive.": {
      "comment": "Oversized-compare warning body; %@ is the diff tool name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ may take a long time to compare them, or become unresponsive."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Программа %@ может долго их сравнивать или перестать отвечать."
          }
        }
      }
    },
    "%@ of %@": {
      "comment": "Queue-bar byte readout: %1$@ transferred of %2$@ total.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ of %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ из %2$@"
          }
        }
      }
    },
    "%@ · newer": {
      "comment": "Conflict card date, flagged as the newer of the two. %@ is a date.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · newer"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · новее"
          }
        }
      }
    },
    "%@ · sizes exclude Git-ignored": {
      "comment": "Pane status line suffix when Git-ignored files are excluded from folder totals. %@ is the count or selection summary it qualifies. One whole clause rather than a concatenated tail, so a translation can reorder it.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · sizes exclude Git-ignored"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · размеры без игнорируемого Git"
          }
        }
      }
    },
    "%@/s": {
      "comment": "Queue-bar throughput readout; %@ is a byte count, e.g. “1.2 MB/s”.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@/s"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@/с"
          }
        }
      }
    },
    "%@: %@": {
      "comment": "Script outcome detail prefixed by the file it failed on; %1$@ file name, %2$@ detail.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@: %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@: %2$@"
          }
        }
      }
    },
    "%lld commits to pull": {
      "comment": "Git branch tooltip; %lld commits are behind upstream. Plural.",
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld commit to pull"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld commits to pull"
                }
              }
            }
          }
        },
        "ru": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld коммит для получения"
                }
              },
              "few": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld коммита для получения"
                }
