    "tour.files.body": {
      "comment": "First-run tour screen 'tour.files': body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The active panel is the source, the other the destination. Copy or move what's selected across, make a folder, or send files to the Trash — from the buttons along the bottom, the function keys, or the palette."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Активная панель — источник, другая — назначение. Копируйте или перемещайте выбранное между ними, создавайте папку или отправляйте файлы в Корзину — кнопками внизу, функциональными клавишами или через палитру."
          }
        }
      },
      "extractionState": "manual"
    },
    "tour.files.title": {
      "comment": "First-run tour screen 'tour.files': title.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move files between panels"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перемещайте файлы между панелями"
          }
        }
      },
      "extractionState": "manual"
    },
    "tour.navigate.body": {
      "comment": "First-run tour screen 'tour.navigate': body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Jump straight to a path, open a second tab, or pin the folders you live in. Location, tabs, and Favorites keep even a deep folder tree a single keystroke away."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Переходите сразу к пути, открывайте вторую вкладку или закрепляйте папки, в которых живёте. Переход к пути, вкладки и Избранное держат даже глубокое дерево папок в одном нажатии клавиши."
          }
        }
      },
      "extractionState": "manual"
    },
    "tour.navigate.title": {
      "comment": "First-run tour screen 'tour.navigate': title.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get anywhere fast"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Быстрый переход куда угодно"
          }
        }
      },
      "extractionState": "manual"
    },
    "tour.palette.body": {
      "comment": "First-run tour screen 'tour.palette': body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open the command palette and start typing what you want to do — copy, pack, connect to a server, tag. It fuzzy-matches every action, so there's nothing to memorize and no menu to hunt through."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте палитру команд и начните вводить, что хотите сделать — копировать, упаковать, подключиться к серверу, поставить тег. Она находит любое действие по нечёткому совпадению, так что ничего не нужно запоминать и не нужно искать по меню."
          }
        }
      },
      "extractionState": "manual"
    },
    "tour.palette.title": {
      "comment": "First-run tour screen 'tour.palette': title.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Everything is one search away"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Всё в одном поиске"
          }
        }
      },
      "extractionState": "manual"
    },
    "tour.ready.body": {
      "comment": "First-run tour screen 'tour.ready': body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS keeps a few folders private — other users' homes, Mail, Time Machine backups. Grant Full Disk Access when you first need one. You can reopen this tour anytime from the command palette."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS держит несколько папок закрытыми — домашние папки других пользователей, Почту, резервные копии Time Machine. Предоставьте полный доступ к диску, когда он впервые понадобится. Этот обзор можно снова открыть в любой момент из палитры команд."
          }
        }
      },
      "extractionState": "manual"
    },
    "tour.ready.title": {
      "comment": "First-run tour screen 'tour.ready': title.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're ready"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы готовы"
          }
        }
      },
      "extractionState": "manual"
    },
    "tour.welcome.body": {
      "comment": "First-run tour screen 'tour.welcome': body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Two panels, side by side, driven from the keyboard. One holds the files you're working with, the other where they're going — and you reach for the mouse only when you want to."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Две панели рядом, управляемые с клавиатуры. В одной — файлы, с которыми вы работаете, в другой — куда они отправляются, а к мыши вы тянетесь, только когда сами захотите."
          }
        }
      },
      "extractionState": "manual"
    },
    "tour.welcome.title": {
