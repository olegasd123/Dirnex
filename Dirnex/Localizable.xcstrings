      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shows each file's tag colours at the right edge of its name, as Finder does. Also in the View menu. Archives and remote volumes have no tags, so nothing is drawn there."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показывает цвета тегов у правого края имени каждого файла, как в Finder. Также доступно в меню «Вид». У архивов и удалённых томов тегов нет, поэтому для них ничего не отображается."
          }
