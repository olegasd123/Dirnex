    },
    "You can browse every folder on this Mac. To change this, open Full Disk Access in System Settings.": {
      "comment": "FDA already-granted sheet body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can browse every folder on this Mac. To change this, open Full Disk Access in System Settings."
          }
