    },
    "The tool Compare By Contents (⌥F3) opens the two files in. Installed: %@. Automatic picks the first of those still installed.": {
      "comment": "Operations footer: diff tools installed. %@ is a comma-separated list.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The tool Compare By Contents (⌥F3) opens the two files in. Installed: %@. Automatic picks the first of those still installed."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Инструмент, в котором «Сравнить по содержимому» (⌥F3) открывает два файла. Установлены: %@. «Автоматически» выбирает первый из ещё установленных."
          }
        }
      }
    },
