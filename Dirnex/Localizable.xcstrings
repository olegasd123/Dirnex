              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld коммитов для получения"
                }
              }
            }
          }
        }
      }
    },
    "%lld commits to push": {
      "comment": "Git branch tooltip; %lld commits are ahead of upstream. Plural.",
      "localizations": {
        "en": {
          "variations": {
