    "%lld items overwrote existing files and can’t be restored.": {
      "comment": "One line of the “undo finished with issues” alert.",
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld item overwrote existing files and can’t be restored."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld items overwrote existing files and can’t be restored."
