    "%lld to copy, %lld to delete": {
      "comment": "Sync status summary; %1$lld files to copy, %2$lld to delete.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld to copy, %lld to delete"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "К копированию: %1$lld, к удалению: %2$lld"
          }
        }
      }
    },
    "(+%lld more)": {
      "comment": "Queue-bar suffix counting the other queued operations; %lld is how many.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "(+%lld more)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "(+%lld ещё)"
          }
        }
      }
    },
    "(unavailable)": {
      "comment": "Shown in place of a host-key fingerprint that couldn’t be read.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "(unavailable)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "(недоступен)"
          }
        }
      }
    },
    "A row of F-key buttons along the window bottom — Rename, View, Copy, Move, New Folder, Delete — the Total Commander function bar. Also in the View menu; the keys work whether or not the bar is shown.": {
      "comment": "Panels footer: function key bar.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A row of F-key buttons along the window bottom — Rename, View, Copy, Move, New Folder, Delete — the Total Commander function bar. Also in the View menu; the keys work whether or not the bar is shown."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ряд кнопок с F-клавишами вдоль нижнего края окна — Переименовать, Просмотр, Копировать, Переместить, Новая папка, Удалить — панель функций Total Commander. Также доступно в меню «Вид»; клавиши работают независимо от того, показана панель или нет."
          }
        }
      }
    },
    "A saved search named “%@” already exists. Replace it?": {
      "comment": "Save-search overwrite confirmation body; %@ is the saved-search name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A saved search named “%@” already exists. Replace it?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сохранённый поиск с именем «%@» уже существует. Заменить его?"
          }
        }
      }
    },
    "A workspace named “%@” already exists. Replace it with the current layout?": {
      "comment": "Replace-workspace confirmation body; %@ is the workspace name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A workspace named “%@” already exists. Replace it with the current layout?"
          }
        },
        "ru": {
