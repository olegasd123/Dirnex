    "Custom": {
      "comment": "Shortcuts preset picker: hand-edited state.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Custom"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пользовательский"
          }
        }
      }
