    "functionBar.file.copy.label": {
      "comment": "FUNCTION BAR — these seven are the app's primary buttons and are always on screen, so they carry the whole app's first impression. Rules for every language: use a WHOLE VERB in the imperative or infinitive, whichever that language uses for menu commands — never a clipped or abbreviated form (write “Копировать”, not “Копир.” or “Копия”), and never a truncation with a period. A noun phrase is acceptable only where the command genuinely names a thing rather than an action (F7 “Новая папка”). Match the wording of the command's own menu title where the verb is the same, so the button and the menu item read as the same command. Prefer the shorter of two correct verbs — the cell is narrow — but never buy width by cutting a word. This button copies the selection to the other panel.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Копировать"
          }
        }
      }
    },
    "functionBar.file.edit.label": {
      "comment": "FUNCTION BAR — these seven are the app's primary buttons and are always on screen, so they carry the whole app's first impression. Rules for every language: use a WHOLE VERB in the imperative or infinitive, whichever that language uses for menu commands — never a clipped or abbreviated form (write “Копировать”, not “Копир.” or “Копия”), and never a truncation with a period. A noun phrase is acceptable only where the command genuinely names a thing rather than an action (F7 “Новая папка”). Match the wording of the command's own menu title where the verb is the same, so the button and the menu item read as the same command. Prefer the shorter of two correct verbs — the cell is narrow — but never buy width by cutting a word. This button opens the file in the user's text editor.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Edit"
          }
        },
        "ru": {
